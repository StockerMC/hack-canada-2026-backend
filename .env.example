DATABASE_URL=postgres://user:password@host/database
SHOPIFY_WEBHOOK_SECRET=replace-with-shopify-webhook-secret

# APNs (optional for conversion push notifications)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=

# Legacy direct wallet endpoint signing config (optional)
WALLET_PASS_TYPE_ID=
WALLET_TEAM_ID=
WALLET_CERT=
WALLET_CERT_PASSWORD=

# Wallet pass provider for persistent wallet identity (server-side only)
WALLETWALLET_API_KEY=
WALLETWALLET_BASE_URL=https://api.walletwallet.dev

# Canonical public API base URL used in generated pass_url values
# e.g. https://api.clipstakes.app
PUBLIC_API_BASE_URL=

# Canonical public video base URL used in upload responses (absolute HTTPS)
# e.g. https://videos.clipstakes.app/clips
# Default behavior (if unset): <PUBLIC_API_BASE_URL or request origin>/upload
PUBLIC_VIDEO_BASE_URL=
